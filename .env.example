# Google Places API key (for business discovery and place details)
GOOGLE_PLACES_API_KEY=

# Google PageSpeed Insights API key (for website auditing)
GOOGLE_PAGESPEED_API_KEY=

# Anthropic API key (for Claude-powered site and email generation)
ANTHROPIC_API_KEY=

# Default location for business discovery (city, province/state)
CURB_DEFAULT_LOCATION=Hamilton, ON

# Default search radius in kilometers
CURB_DEFAULT_RADIUS_KM=15

# Your name (used in outreach emails)
CURB_OWNER_NAME=

# Your business name (used in outreach emails)
CURB_BUSINESS_NAME=

# Your business address (used in outreach emails)
CURB_BUSINESS_ADDRESS=

# Your business email (used as reply-to in outreach emails)
CURB_BUSINESS_EMAIL=

# Base URL where generated sites are hosted
CURB_SITE_BASE_URL=http://localhost:3000/sites
